# NTRIP Caster Configuration
NTRIP_ENABLED=false
NTRIP_HOST=
NTRIP_PORT=2101
NTRIP_MOUNTPOINT=
NTRIP_USERNAME=
NTRIP_PASSWORD=

# LoRa Streaming Configuration
# Enable LoRa RTCM streaming to rover via E22-900T22U module
LORA_ENABLED=false
LORA_PORT=/dev/ttyUSB0
LORA_BAUDRATE=115200
LORA_PACKET_SIZE=240

# Serial Port
SERIAL_PORT=/dev/ttyAMA0
SERIAL_BAUDRATE=38400

# FastAPI
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
DEBUG=false
LOG_LEVEL=INFO
